# .env - Development Configuration
# Thay đổi các giá trị này cho environment của bạn

# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production-autorent-backend-2026
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ENVIRONMENT=development

# Database (SQLite for development)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Email (Console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@autorent.vn

# HTTPS & Security (Disabled for development)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Logging
LOG_LEVEL=DEBUG

# Sentry (Optional - comment out if not using)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1
