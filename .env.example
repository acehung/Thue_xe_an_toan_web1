# .env.example
# Sao chép file này thành .env và điền các giá trị thực
# Ví dụ: cp .env.example .env
# KHÔNG commit .env vào Git!

# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-django-insecure-xxxxx
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,autorent.vn,www.autorent.vn,api.autorent.vn
ENVIRONMENT=production

# Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=autorent_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your-secure-db-password
DATABASE_HOST=db.example.com
DATABASE_PORT=5432

# Redis (Cache & Sessions)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@autorent.vn

# HTTPS & SSL
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://frontend.autorent.vn,https://app.autorent.vn
CORS_ALLOW_CREDENTIALS=True

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800
JWT_ALGORITHM=HS256

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment Gateway (VNPay)
VNPAY_MERCHANT_ID=your_vnpay_merchant_id
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_API_URL=https://sandbox.vnpayment.vn

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# SMS/OTP Service (Twilio or Nexmo)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# GPS Tracking Service
GPS_API_KEY=your_gps_api_key
GPS_PROVIDER=google_maps

# Maps & Geolocation
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_API_TOKEN=your_mapbox_api_token

# AWS S3 (Media Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME=autorent-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=media.autorent.vn

# File Upload Settings
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif
ALLOWED_DOCUMENT_FORMATS=pdf,doc,docx

# API Rate Limiting
RATE_LIMIT_LOGIN=5/h
RATE_LIMIT_API=100/h
RATE_LIMIT_UPLOAD=10/h

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/django/app.log
LOG_MAX_BYTES=15728640  # 15MB
LOG_BACKUP_COUNT=10

# Security Headers
X_FRAME_OPTIONS=DENY
SECURE_CONTENT_SECURITY_POLICY=default-src 'self'

# Session Settings
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# CSRF Settings
CSRF_COOKIE_HTTPONLY=False
CSRF_COOKIE_SAMESITE=Strict
CSRF_TRUSTED_ORIGINS=https://autorent.vn,https://www.autorent.vn

# API Documentation
API_DOCUMENTATION_ENABLED=True
SWAGGER_ENABLED=True

# Feature Flags
FEATURE_2FA_ENABLED=True
FEATURE_GPS_TRACKING=True
FEATURE_INSURANCE_INTEGRATION=True
FEATURE_PAYMENT_GATEWAY=True

# Admin Settings
ADMIN_URL=/secure-admin/
ADMIN_LOG_RETENTION_DAYS=90

# Backup Settings
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # 2:00 AM daily
BACKUP_RETENTION_DAYS=30

# Celery (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
